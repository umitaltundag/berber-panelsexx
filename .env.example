# BerberPanel Environment Variables
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.

# Database - Local: SQLite dosyası, Production: Turso URL
# Turso için: libsql://<db-adı>.turso.io?authToken=<token>
DATABASE_URL=file:./prisma/dev.db

# JWT secret key (en az 32 karakter, rastgele bir değer kullanın)
JWT_SECRET=berber-panel-secret-key-2026
